---

<footer class="bg-black text-white mt-16 md:mt-24">
	<div class="max-w-6xl mx-auto px-5 md:px-8 py-10 md:py-16">

		<!-- Mobile: stacked | Desktop: 4-column grid -->
		<div class="flex flex-col gap-10 md:grid md:grid-cols-4 md:gap-12">

			<!-- Brand -->
			<div>
				<div class="flex items-baseline">
					<span class="font-serif text-[28px]">CookScale</span>
					<span class="text-[28px]" style="color: var(--color-primary)">.</span>
				</div>
				<p class="mt-3 text-white/60 text-[14px] leading-relaxed">
					Dokładne makro po obróbce termicznej. Bez zgadywania.
				</p>
			</div>

			<!-- Produkt -->
			<div>
				<h4 class="font-serif text-[18px] mb-4" style="color: var(--color-primary)">Produkt</h4>
				<ul class="space-y-3 text-[15px] text-white/80">
					<li><a href="/calculator" class="hover:text-white transition-colors">Kalkulator</a></li>
					<li><a href="/ai" class="hover:text-white transition-colors">Danie z AI</a></li>
					<li><a href="/history" class="hover:text-white transition-colors">Historia</a></li>
				</ul>
			</div>

			<!-- Pomoc -->
			<div>
				<h4 class="font-serif text-[18px] mb-4" style="color: var(--color-primary)">Pomoc</h4>
				<ul class="space-y-3 text-[15px] text-white/80">
					<li><a href="#" class="hover:text-white transition-colors">FAQ</a></li>
					<li><a href="#" class="hover:text-white transition-colors">Kontakt</a></li>
					<li><a href="#" class="hover:text-white transition-colors">Polityka prywatności</a></li>
				</ul>
			</div>

			<!-- Język -->
			<div>
				<h4 class="font-serif text-[18px] mb-4" style="color: var(--color-primary)">Język</h4>
				<ul class="space-y-3 text-[15px] text-white/80">
					<li><span class="cursor-pointer hover:text-white transition-colors">Polski</span></li>
					<li><span class="cursor-pointer hover:text-white transition-colors">English</span></li>
				</ul>
			</div>
		</div>
	</div>

	<div class="border-t border-white/10">
		<div class="max-w-6xl mx-auto px-5 md:px-8 py-6 text-[13px] text-white/40">
			© 2026 CookScale. POC web.
		</div>
	</div>
</footer>
