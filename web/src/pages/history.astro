---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const pathname = Astro.url.pathname;

const MOCK = [
	{
		type: "product",
		name: "Pierś z kurczaka",
		meta: "200g surowe · pieczenie",
		kcal: 240,
		when: "Dziś, 12:48",
	},
	{
		type: "dish",
		name: "Spaghetti bolognese",
		meta: "Danie AI · 612g po obróbce",
		kcal: 945,
		when: "Wczoraj, 19:12",
	},
	{
		type: "product",
		name: "Ryż biały",
		meta: "80g surowy · gotowanie",
		kcal: 288,
		when: "8 maja, 13:01",
	},
];
---

<BaseLayout title="Historia — CookScale" description="Twoje zapisane obliczenia makro.">
	<Header currentPath={pathname} />
	<main class="max-w-4xl mx-auto px-5 md:px-8 py-8 md:py-16">
		<p class="text-[13px] uppercase tracking-widest" style="color: var(--color-muted-foreground)">
			Historia
		</p>
		<h1 class="mt-2 md:mt-3">Twoje obliczenia.</h1>
		<p
			class="mt-3 md:mt-4 text-[15px] md:text-[16px] max-w-2xl"
			style="color: var(--color-muted-foreground)"
		>
			Zaloguj się, aby zapisywać obliczenia automatycznie. Poniżej przykładowe wpisy.
		</p>

		<ul class="mt-10 space-y-3">
			{
				MOCK.map((m) => (
					<li class="card-soft px-4 md:px-6 py-4 md:py-5 flex items-center justify-between gap-3 md:gap-4">
						<div class="flex items-center gap-3 md:gap-4 min-w-0">
							<span
								class="w-10 h-10 shrink-0 rounded-full grid place-items-center text-[18px]"
								style={
									m.type === "dish"
										? "background: var(--color-primary-light)"
										: "background: var(--color-secondary)"
								}
							>
								{m.type === "dish" ? "🍝" : "🥩"}
							</span>
							<div class="min-w-0">
								<p class="font-serif text-[18px] md:text-[20px] truncate">{m.name}</p>
								<p class="text-[13px]" style="color: var(--color-muted-foreground)">
									{m.meta}
								</p>
							</div>
						</div>
						<div class="text-right">
							<p class="text-[16px]" style="color: var(--color-primary)">
								{m.kcal} kcal
							</p>
							<p class="text-[12px]" style="color: var(--color-muted-foreground)">
								{m.when}
							</p>
						</div>
					</li>
				))
			}
		</ul>

		<div
			class="mt-8 md:mt-10 rounded-3xl px-5 md:px-8 py-8 md:py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4"
			style="background: var(--color-primary-light)"
		>
			<div>
				<h3 class="font-serif text-[24px]">Zachowaj swoje wyniki</h3>
				<p class="mt-2 text-[15px]" style="color: var(--color-muted-foreground)">
					Załóż darmowe konto, aby historia synchronizowała się między urządzeniami.
				</p>
			</div>
			<a href="/login" class="btn-dark whitespace-nowrap">Zarejestruj się</a>
		</div>
	</main>
	<Footer />
</BaseLayout>
