---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import type { HistoryRow } from "@/components/pages/history-page";
import { HistoryPage } from "@/components/pages/history-page";

import { getPageMeta } from "@/lib/page-meta";

const pathname = Astro.url.pathname;
const { user, supabase, lang } = Astro.locals;
const meta = getPageMeta(lang, "history");

const { data: calculations } = await supabase
  .from("calculations")
  .select("id,type,direction,created_at,input,result,input_text")
  .order("created_at", { ascending: false })
  .limit(50);

type Calculation = NonNullable<typeof calculations>[number];

const toRow = (c: Calculation): HistoryRow => {
  const r = c.result as Record<string, unknown> | null;
  const kcal =
    c.type === "dish"
      ? ((r?.total as Record<string, unknown>)?.calories_kcal as
          | number
          | undefined)
      : ((r?.macros_total as Record<string, unknown>)?.calories_kcal as
          | number
          | undefined);

  let name = "Obliczenie";
  let meta = "";

  if (c.type === "dish") {
    name = (c.input_text as string | null)?.slice(0, 40) ?? "Danie AI";
    const weightG = r?.total_weight_g as number | undefined;
    meta = `Danie AI${weightG ? ` · ${weightG}g po obróbce` : ""}`;
  } else {
    const inp = c.input as Record<string, unknown> | null;
    name = (inp?.product_name as string | null) ?? "Produkt";
    const method = inp?.cooking_method_slug as string | null;
    const weight = inp?.weight_g as number | null;
    const dir = c.direction === "raw_to_cooked" ? "surowe" : "ugotowane";
    meta = [weight ? `${weight}g ${dir}` : null, method]
      .filter(Boolean)
      .join(" · ");
  }

  return {
    id: c.id,
    type: c.type,
    name,
    meta,
    kcal: kcal != null ? Math.round(kcal) : null,
    when: c.created_at,
  };
};

const rows = (calculations ?? []).map(toRow);
---

<BaseLayout title={meta.title} description={meta.description}>
  <Header currentPath={pathname} user={user} />
  <HistoryPage rows={rows} client:load />
  <Footer />
</BaseLayout>
