---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { format, isToday, isYesterday } from "date-fns";
import { pl } from "date-fns/locale";

const pathname = Astro.url.pathname;
const { user, supabase } = Astro.locals;

const { data: calculations } = await supabase
	.from("calculations")
	.select("id,type,direction,created_at,input,result,input_text")
	.order("created_at", { ascending: false })
	.limit(50);

type Calculation = NonNullable<typeof calculations>[number];

const formatWhen = (iso: string) => {
	const d = new Date(iso);
	if (isToday(d)) return `Dziś, ${format(d, "HH:mm")}`;
	if (isYesterday(d)) return `Wczoraj, ${format(d, "HH:mm")}`;
	return format(d, "d MMM, HH:mm", { locale: pl });
};

const toRow = (c: Calculation) => {
	const r = c.result as Record<string, unknown> | null;
	const kcal =
		c.type === "dish"
			? ((r?.total as Record<string, unknown>)?.calories_kcal as
					| number
					| undefined)
			: ((r?.macros_total as Record<string, unknown>)?.calories_kcal as
					| number
					| undefined);

	let name = "Obliczenie";
	let meta = "";

	if (c.type === "dish") {
		name = (c.input_text as string | null)?.slice(0, 40) ?? "Danie AI";
		const weightG = r?.total_weight_g as number | undefined;
		meta = `Danie AI${weightG ? ` · ${weightG}g po obróbce` : ""}`;
	} else {
		const inp = c.input as Record<string, unknown> | null;
		name = (inp?.product_name as string | null) ?? "Produkt";
		const method = inp?.cooking_method_slug as string | null;
		const weight = inp?.weight_g as number | null;
		const dir = c.direction === "raw_to_cooked" ? "surowe" : "ugotowane";
		meta = [weight ? `${weight}g ${dir}` : null, method]
			.filter(Boolean)
			.join(" · ");
	}

	return {
		id: c.id,
		type: c.type,
		name,
		meta,
		kcal: kcal != null ? Math.round(kcal) : null,
		when: formatWhen(c.created_at),
	};
};

const rows = (calculations ?? []).map(toRow);
---

<BaseLayout
	title="Historia — CookScale"
	description="Twoje zapisane obliczenia makro."
>
	<Header currentPath={pathname} user={user} />
	<main class="max-w-4xl mx-auto px-5 md:px-8 py-8 md:py-16">
		<p
			class="text-[13px] uppercase tracking-widest"
			style="color: var(--color-muted-foreground)"
		>
			Historia
		</p>
		<h1 class="mt-2 md:mt-3">Twoje obliczenia.</h1>
		<p
			class="mt-3 md:mt-4 text-[15px] md:text-[16px] max-w-2xl"
			style="color: var(--color-muted-foreground)"
		>
			Wszystkie obliczenia zapisane na Twoim koncie.
		</p>

		{
			rows.length === 0 ? (
				<div
					class="mt-10 rounded-3xl px-5 md:px-8 py-10 md:py-14 text-center"
					style="background: var(--color-secondary)"
				>
					<p class="font-serif text-[22px]">Brak obliczeń</p>
					<p
						class="mt-2 text-[15px]"
						style="color: var(--color-muted-foreground)"
					>
						Wykonaj pierwsze obliczenie w kalkulatorze lub trybie AI.
					</p>
					<div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
						<a href="/calculator" class="btn-primary">
							Kalkulator produktów
						</a>
						<a href="/ai" class="btn-outline">
							Tryb AI →
						</a>
					</div>
				</div>
			) : (
				<ul class="mt-10 space-y-3">
					{rows.map((m) => (
						<li class="card-soft px-4 md:px-6 py-4 md:py-5 flex items-center justify-between gap-3 md:gap-4">
							<div class="flex items-center gap-3 md:gap-4 min-w-0">
								<span
									class="w-10 h-10 shrink-0 rounded-full grid place-items-center text-[18px]"
									style={
										m.type === "dish"
											? "background: var(--color-primary-light)"
											: "background: var(--color-secondary)"
									}
								>
									{m.type === "dish" ? "🍝" : "🥩"}
								</span>
								<div class="min-w-0">
									<p class="font-serif text-[18px] md:text-[20px] truncate">
										{m.name}
									</p>
									<p
										class="text-[13px]"
										style="color: var(--color-muted-foreground)"
									>
										{m.meta}
									</p>
								</div>
							</div>
							<div class="text-right shrink-0">
								{m.kcal != null && (
									<p class="text-[16px]" style="color: var(--color-primary)">
										{m.kcal} kcal
									</p>
								)}
								<p
									class="text-[12px]"
									style="color: var(--color-muted-foreground)"
								>
									{m.when}
								</p>
							</div>
						</li>
					))}
				</ul>
			)
		}
	</main>
	<Footer />
</BaseLayout>
