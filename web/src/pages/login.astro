---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { LoginForm } from "@/components/login-form";

const pathname = Astro.url.pathname;
---

<BaseLayout
	title="Zaloguj się — CookScale"
	description="Zaloguj się do CookScale, aby zapisywać historię obliczeń makro."
	robots="noindex, follow"
	ogTitle="Zaloguj się — CookScale"
	ogDescription="Twoja historia makro w jednym miejscu."
>
	<Header currentPath={pathname} />
	<main class="max-w-6xl mx-auto px-5 md:px-8 py-8 md:py-20">
		<div class="grid lg:grid-cols-2 gap-8 lg:gap-20 items-center">
			<!-- Left — editorial copy -->
			<div class="hidden lg:block">
				<p
					class="text-[13px] uppercase tracking-widest"
					style="color: var(--color-muted-foreground)"
				>
					Witaj ponownie
				</p>
				<h1 class="mt-4">
					Twoje makro, <em class="italic font-light">w jednym miejscu.</em>
				</h1>
				<p class="mt-6 text-[17px] max-w-md" style="color: var(--color-muted-foreground)">
					Zaloguj się, aby zsynchronizować historię obliczeń, ulubione produkty i własne yieldy
					między urządzeniami.
				</p>
				<ul class="mt-10 space-y-4 text-[15px]" style="color: var(--color-muted-foreground)">
					{
						[
							"Synchronizacja historii w chmurze",
							"Własne współczynniki obróbki",
							"Bez reklam, bez śledzenia",
						].map((t) => (
							<li class="flex items-center gap-3">
								<span class="w-1.5 h-1.5 rounded-full" style="background: var(--color-primary)" />
								{t}
							</li>
						))
					}
				</ul>
			</div>

			<!-- Right — interactive login form -->
			<LoginForm client:load />
		</div>
	</main>
	<Footer />
</BaseLayout>
