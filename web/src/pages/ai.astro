---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { AiCalculator } from "@/components/ai-calculator";

const pathname = Astro.url.pathname;
const { user } = Astro.locals;
---

<BaseLayout
	title="Danie z AI — CookScale"
	description="Opisz danie po polsku — AI policzy makro całego posiłku."
>
	<Header currentPath={pathname} user={user} />
	<main class="max-w-4xl mx-auto px-5 md:px-8 py-8 md:py-16">
		<div class="flex items-center gap-3">
			<span
				class="text-[13px] uppercase tracking-widest"
				style="color: var(--color-muted-foreground)">Tryb AI</span
			>
			<span
				class="text-[12px] px-3 py-1 rounded-full"
				style="background: var(--color-announcement)"
			>
				1 darmowy trial
			</span>
		</div>
		<h1 class="mt-2 md:mt-3">
			Opisz danie. <em class="italic font-light">AI policzy makro.</em>
		</h1>
		<p
			class="mt-3 md:mt-4 text-[15px] md:text-[16px] max-w-2xl"
			style="color: var(--color-muted-foreground)"
		>
			Wpisz składniki z gramaturami i metodą obróbki. Otrzymasz całkowitą masę
			dania oraz makro całe i na 100g.
		</p>

		<AiCalculator client:load />
	</main>
	<Footer />
</BaseLayout>
