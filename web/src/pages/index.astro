---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { AnnouncementBar } from "@/components/announcement-bar";
import { ProductCalculator } from "@/components/product-calculator";

const pathname = Astro.url.pathname;
---

<BaseLayout
	title="CookScale — surowe vs. po obróbce w sekundę"
	description="Licz makro produktów po gotowaniu, smażeniu i pieczeniu. Wpisz danie po polsku — AI policzy całość."
>
	<AnnouncementBar client:load />
	<Header currentPath={pathname} />
	<main>
		<!-- Hero -->
		<section class="max-w-6xl mx-auto px-5 md:px-8 pt-10 md:pt-24 pb-12 md:pb-16">
			<div class="grid lg:grid-cols-[1.1fr_1fr] gap-8 lg:gap-12 items-center">
				<div>
					<span
						class="inline-flex items-center gap-2 text-[13px] px-3 py-1 rounded-full"
						style="background: var(--color-primary-light); color: var(--color-primary)"
					>
						<span class="w-1.5 h-1.5 rounded-full" style="background: var(--color-primary)"></span>
						Raw → Cooked. W kilka sekund.
					</span>
					<h1 class="mt-5 md:mt-6">
						Dokładne makro <em class="italic font-light">po obróbce</em> termicznej.
					</h1>
					<p
						class="mt-4 md:mt-6 max-w-xl text-[16px] md:text-[17px]"
						style="color: var(--color-muted-foreground)"
					>
						Wpisz gramaturę surowego ryżu — zobacz, ile będzie ważył ugotowany. Albo na odwrót. Dla
						złożonych dań użyj trybu AI: opisz przepis po polsku, dostaniesz makro całego posiłku.
					</p>
					<div class="mt-6 md:mt-8 flex flex-col sm:flex-row gap-3">
						<a href="/calculator" class="btn-primary text-center">Otwórz kalkulator</a>
						<a href="/ai" class="btn-outline text-center">Wypróbuj AI →</a>
					</div>
					<ul class="mt-8 md:mt-10 space-y-3 text-[15px]">
						{
							[
								"3 metody: gotowanie, smażenie, pieczenie",
								"Tryb odwrotny: z ugotowanego do surowego",
								"Historia obliczeń dla zarejestrowanych",
							].map((t) => (
								<li class="flex items-start gap-3">
									<svg
										class="mt-0.5 shrink-0"
										width="18"
										height="18"
										viewBox="0 0 18 18"
										fill="none"
										aria-hidden="true"
									>
										<circle cx="9" cy="9" r="9" fill="var(--color-primary-light)" />
										<path
											d="M5 9l3 3 5-5"
											stroke="var(--color-primary)"
											stroke-width="1.5"
											stroke-linecap="round"
											stroke-linejoin="round"
										/>
									</svg>
									<span>{t}</span>
								</li>
							))
						}
					</ul>
				</div>

				<div class="card-soft p-5 md:p-8">
					<p
						class="text-[12px] uppercase tracking-widest"
						style="color: var(--color-muted-foreground)"
					>
						Szybki podgląd
					</p>
					<div class="mt-3 flex items-baseline justify-between">
						<h3 class="font-serif text-[22px] md:text-[26px]">Pierś z kurczaka</h3>
						<span
							class="text-[12px] px-3 py-1 rounded-full shrink-0 ml-2"
							style="background: var(--color-primary-light); color: var(--color-primary)"
						>
							Pieczenie
						</span>
					</div>
					<div class="mt-5 grid grid-cols-2 gap-3">
						<div class="rounded-2xl p-4 md:p-5" style="background: var(--color-primary-muted)">
							<p
								class="text-[11px] uppercase tracking-widest"
								style="color: var(--color-muted-foreground)"
							>
								Surowo
							</p>
							<p class="font-serif text-[24px] md:text-[28px] mt-2">200 g</p>
						</div>
						<div class="rounded-2xl p-4 md:p-5" style="background: var(--color-primary-light)">
							<p
								class="text-[11px] uppercase tracking-widest"
								style="color: var(--color-muted-foreground)"
							>
								Po pieczeniu
							</p>
							<p
								class="font-serif text-[24px] md:text-[28px] mt-2"
								style="color: var(--color-primary)"
							>
								150 g
							</p>
						</div>
					</div>
					<div class="mt-4 grid grid-cols-4 gap-2 md:gap-3 text-center">
						{
							[
								["240", "kcal"],
								["45", "B"],
								["5.2", "T"],
								["0", "W"],
							].map(([v, l]) => (
								<div class="rounded-xl py-3" style="background: var(--color-secondary)">
									<p class="font-serif text-[18px] md:text-[20px]">{v}</p>
									<p class="text-[11px]" style="color: var(--color-muted-foreground)">
										{l}
									</p>
								</div>
							))
						}
					</div>
					<a href="/calculator" class="btn-dark w-full mt-6 md:mt-8">Policz swoje</a>
				</div>
			</div>
		</section>

		<!-- Stats / social proof -->
		<section class="section-light">
			<div
				class="max-w-6xl mx-auto px-5 md:px-8 py-10 md:py-16 grid grid-cols-3 md:grid-cols-3 gap-5 md:gap-8"
			>
				{
					[
						["10s", "Średni czas do wyniku"],
						["3", "Metody obróbki w MVP"],
						["<10%", "Cel błędu vs. USDA"],
					].map(([v, l]) => (
						<div>
							<p
								class="font-serif text-[36px] md:text-[56px] leading-none"
								style="color: var(--color-primary)"
							>
								{v}
							</p>
							<p
								class="mt-2 md:mt-3 text-[13px] md:text-[15px]"
								style="color: var(--color-muted-foreground)"
							>
								{l}
							</p>
						</div>
					))
				}
			</div>
		</section>

		<!-- Inline calculator -->
		<section class="max-w-6xl mx-auto px-5 md:px-8 py-12 md:py-20">
			<div class="max-w-2xl">
				<h2>Przelicz <em class="italic font-light">teraz</em>, bez logowania.</h2>
				<p
					class="mt-3 md:mt-4 text-[15px] md:text-[16px]"
					style="color: var(--color-muted-foreground)"
				>
					Wybierz produkt, podaj gramaturę i metodę. Wynik zobaczysz natychmiast.
				</p>
			</div>
			<div class="mt-8 md:mt-10">
				<ProductCalculator client:load />
			</div>
		</section>

		<!-- CTA -->
		<section class="max-w-6xl mx-auto px-5 md:px-8 pb-12 md:pb-20">
			<div
				class="rounded-2xl md:rounded-3xl px-6 md:px-14 py-10 md:py-16 flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between"
				style="background: var(--color-primary-light)"
			>
				<div>
					<h2 class="max-w-2xl">Złożone danie? <em class="italic font-light">Opisz je AI.</em></h2>
					<p
						class="mt-3 text-[15px] md:text-[16px] max-w-2xl"
						style="color: var(--color-muted-foreground)"
					>
						„Makaron 200g, mięso mielone 150g, przecier 100g, oliwa łyżka." — pełne makro w 5
						sekund.
					</p>
				</div>
				<a href="/ai" class="btn-dark w-full md:w-auto whitespace-nowrap">Spróbuj AI →</a>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
