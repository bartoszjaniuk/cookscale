---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { AnnouncementBar } from "@/components/announcement-bar";
import { HomePage } from "@/components/pages/home-page";
import { getPageMeta } from "@/lib/page-meta";

const pathname = Astro.url.pathname;
const { user, lang } = Astro.locals;
const meta = getPageMeta(lang, "home");
---

<BaseLayout title={meta.title} description={meta.description}>
  <AnnouncementBar client:load />
  <Header currentPath={pathname} user={user} />
  <HomePage client:load />
  <Footer />
</BaseLayout>
