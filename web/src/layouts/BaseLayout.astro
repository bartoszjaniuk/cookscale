---
import "@/styles/global.css";
import i18next from "@/i18n";

interface Props {
  title: string;
  description?: string;
  robots?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title,
  description = "Macro calculator: raw ↔ after cooking. Product mode and AI for whole dishes.",
  robots,
  ogTitle,
  ogDescription,
} = Astro.props;

const lang = Astro.locals.lang || "en";
i18next.changeLanguage(lang);

const themeBootstrap = `(function(){try{var t=localStorage.getItem('cookscale-theme')||'light';if(t==='dark')document.documentElement.classList.add('dark');document.documentElement.dataset.theme=t;document.documentElement.dataset.colorTheme='amber';}catch(e){}})();`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "CookScale",
  description:
    "Kalkulator makro: surowe ↔ po obróbce. Tryb produktu i AI dla całych dań.",
  applicationCategory: "HealthApplication",
  operatingSystem: "Web",
  inLanguage: "pl-PL",
  offers: { "@type": "Offer", price: "0", priceCurrency: "PLN" },
});
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    {ogTitle && <meta property="og:title" content={ogTitle} />}
    {
      ogDescription && (
        <meta property="og:description" content={ogDescription} />
      )
    }
    <link
      rel="preload"
      href="/fonts/BasierCircle-Regular.woff"
      as="font"
      type="font/woff"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/BasierSquare-Regular.woff"
      as="font"
      type="font/woff"
      crossorigin
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <script is:inline set:html={themeBootstrap} />
    <script type="application/ld+json" set:html={jsonLd} />
    <!--
			Initialize the i18next singleton here, once per page load.
			Astro hydrates each `client:load` component as an independent island —
			outside the React tree. By importing here (processed by Vite as a module
			script), i18next is ready before any island mounts, so no component needs
			to import it individually.
		-->
    <script>
      import "@/i18n";
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
